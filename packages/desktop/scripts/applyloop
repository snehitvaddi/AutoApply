#!/usr/bin/env bash
# ApplyLoop CLI shim — installed via symlink at ~/.local/bin/applyloop.
#
#   applyloop start      — open the .app (which execs the venv launcher)
#   applyloop run        — chat with Claude Code in this terminal (no .app)
#   applyloop stop       — kill the running launch.py process
#   applyloop status     — GET /api/health and pretty-print
#   applyloop logs       — tail ~/.autoapply/desktop.log
#   applyloop update     — git pull + pip reinstall + UI rebuild + regen .app
#   applyloop uninstall  — remove ~/.applyloop, /Applications/ApplyLoop.app, the shim
set -euo pipefail

APPLYLOOP_HOME="${APPLYLOOP_HOME:-$HOME/.applyloop}"
APPLYLOOP_APP="${APPLYLOOP_APP:-/Applications/ApplyLoop.app}"
APPLYLOOP_BRANCH="${APPLYLOOP_BRANCH:-main}"
PORT="${APPLYLOOP_PORT:-18790}"
LOG="$HOME/.autoapply/desktop.log"
# Match install.sh: pin npm cache inside $APPLYLOOP_HOME so `applyloop
# update` doesn't trip on a global /tmp/npm-cache or ~/.npm with
# foreign-owned files.
export NPM_CONFIG_CACHE="$APPLYLOOP_HOME/.npm-cache"
mkdir -p "$NPM_CONFIG_CACHE" 2>/dev/null || true

log() { echo "[applyloop] $*"; }

cmd_start() {
  if [[ ! -d "$APPLYLOOP_APP" ]]; then
    echo "ApplyLoop.app not found at $APPLYLOOP_APP — run the curl installer first." >&2
    exit 1
  fi

  # Self-heal stale state that silently breaks startup. Users hit this
  # mostly after kernel-level kills (force quit, OOM, system restart
  # mid-shutdown) — the .app's atexit hooks don't fire and the next
  # `open` either bails because lifespan thinks another desktop is
  # alive, or the new uvicorn fails to bind because a zombie holds the
  # port. Both are invisible to the user ("site can't be reached" /
  # "nothing happened").

  # 1. Stale desktop.pid — lifespan reads this and may decide not to
  # sweep the gateway, leaving Chrome in a broken state. Remove if PID
  # is dead.
  local pid_file="$APPLYLOOP_HOME/desktop.pid"
  if [[ -f "$pid_file" ]]; then
    local pid
    pid="$(tr -d '[:space:]' < "$pid_file" 2>/dev/null || echo)"
    if [[ -n "$pid" ]] && ! kill -0 "$pid" 2>/dev/null; then
      log "Removing stale desktop.pid ($pid is dead)"
      rm -f "$pid_file"
    fi
  fi

  # 2. Port hijack — anything bound to 18790 that isn't an ApplyLoop
  # process needs to clear out, otherwise uvicorn errors out on bind
  # and the .app exits silently. lsof -nP -iTCP:18790 -sTCP:LISTEN.
  local listener_pid
  listener_pid="$(lsof -nP -iTCP:"$PORT" -sTCP:LISTEN -t 2>/dev/null | head -1 || true)"
  if [[ -n "$listener_pid" ]]; then
    local listener_cmd
    listener_cmd="$(ps -o comm= -p "$listener_pid" 2>/dev/null || true)"
    # Conservative: only kill if it's clearly a stale ApplyLoop. The
    # launcher process is `Python` and `python3.x`; the .app's own
    # name doesn't show up because we exec the venv python directly.
    # Match the launch.py path in the args list instead.
    if ps -p "$listener_pid" -o command= 2>/dev/null | grep -q "packages/desktop/launch.py"; then
      log "Killing stale ApplyLoop python on port $PORT (pid $listener_pid)"
      kill "$listener_pid" 2>/dev/null || true
      sleep 1
      kill -0 "$listener_pid" 2>/dev/null && kill -9 "$listener_pid" 2>/dev/null || true
    else
      echo "Port $PORT is held by another process (pid $listener_pid, $listener_cmd)." >&2
      echo "Free it first, then run 'applyloop start' again." >&2
      exit 1
    fi
  fi

  # 3. macOS quarantine — re-installs from a curl pipe sometimes land
  # with com.apple.quarantine set, which makes Gatekeeper silently
  # refuse to exec the bash launcher. The .app appears in Dock for a
  # heartbeat and vanishes. Strip the xattr; it's a no-op when absent.
  xattr -dr com.apple.quarantine "$APPLYLOOP_APP" 2>/dev/null || true

  log "Opening $APPLYLOOP_APP"
  open "$APPLYLOOP_APP"

  # Verify the server actually came up. If it didn't, the user
  # otherwise sees nothing — no window, no error, just a dead Dock
  # icon. Poll /api/health for up to 60s (cold start includes openclaw
  # gateway probe and the LLM API key load), then dump the tail of
  # the log so the failure mode is visible at the same prompt the
  # user ran `applyloop start` from.
  local deadline=$(($(date +%s) + 60))
  while (( $(date +%s) < deadline )); do
    if curl -sS --max-time 2 "http://localhost:$PORT/api/health" >/dev/null 2>&1; then
      log "Server is up at http://localhost:$PORT"
      return 0
    fi
    sleep 1
  done

  echo
  echo "[applyloop] Server did not come up within 60s." >&2
  echo "[applyloop] Last 30 lines of $LOG:" >&2
  if [[ -f "$LOG" ]]; then
    tail -30 "$LOG" >&2
  else
    echo "  (no log file at $LOG — launcher may not have run)" >&2
  fi
  exit 1
}

cmd_run() {
  # Terminal CLI — chat with Claude Code right in this terminal, no .app
  # window. Same server (browser gateway + worker + PTY Claude +
  # dashboard) as the app; launch.py just bridges the PTY to the terminal
  # instead of opening pywebview. exec so signals go straight to python.
  local py="$APPLYLOOP_HOME/venv/bin/python3"
  local launcher="$APPLYLOOP_HOME/packages/desktop/launch.py"
  if [[ ! -x "$py" ]]; then
    echo "venv python not found at $py — run the curl installer first." >&2
    exit 1
  fi
  if [[ ! -f "$launcher" ]]; then
    echo "launch.py not found at $launcher — run 'applyloop update'." >&2
    exit 1
  fi
  # Arch guard — refuse to exec a wrong-arch venv. Otherwise macOS would
  # pop the cold "install Rosetta" dialog with no context.
  local host_arch venv_arch
  host_arch="$(uname -m)"
  venv_arch="$("$py" -c 'import platform; print(platform.machine())' 2>/dev/null || echo unknown)"
  if [[ "$venv_arch" != "$host_arch" ]]; then
    echo "venv python at $py reports arch '$venv_arch' but this Mac is '$host_arch'." >&2
    echo "Re-run the installer to rebuild it natively:" >&2
    echo "  curl -fsSL https://raw.githubusercontent.com/snehitvaddi/ApplyLoop/main/install.sh | bash" >&2
    exit 1
  fi
  exec "$py" "$launcher" run
}

cmd_stop() {
  if pgrep -f "$APPLYLOOP_HOME/packages/desktop/launch.py" >/dev/null 2>&1; then
    log "Stopping running launch.py under $APPLYLOOP_HOME"
    pkill -f "$APPLYLOOP_HOME/packages/desktop/launch.py" 2>/dev/null || true
    sleep 1
    if pgrep -f "$APPLYLOOP_HOME/packages/desktop/launch.py" >/dev/null 2>&1; then
      log "Graceful kill failed, sending SIGKILL"
      pkill -9 -f "$APPLYLOOP_HOME/packages/desktop/launch.py" 2>/dev/null || true
    fi
    log "Stopped"
  else
    log "Not running"
  fi
}

cmd_status() {
  local out
  if out="$(curl -sS --max-time 3 "http://localhost:$PORT/api/health" 2>/dev/null)"; then
    if [[ -n "$out" ]]; then
      echo "$out" | python3 -m json.tool 2>/dev/null || echo "$out"
      return 0
    fi
  fi
  echo "Not running (no response on http://localhost:$PORT/api/health)"
  return 1
}

cmd_logs() {
  if [[ ! -f "$LOG" ]]; then
    echo "No log yet at $LOG — has ApplyLoop ever been started?"
    exit 1
  fi
  tail -f "$LOG"
}

cmd_update() {
  if [[ ! -d "$APPLYLOOP_HOME/.git" ]]; then
    echo "No git repo at $APPLYLOOP_HOME — run the curl installer first." >&2
    exit 1
  fi

  # Concurrency lock — prevents the daily 3 AM launchd run from
  # colliding with a manual `applyloop update` invoked at the same
  # moment, which would race on .git/index.lock and the venv. The
  # lock is a marker file with the holder's PID; if a stale lock from
  # a crashed prior update is present (PID dead), we steal it.
  local LOCKFILE="$HOME/.autoapply/.update.lock"
  mkdir -p "$(dirname "$LOCKFILE")"
  if [[ -f "$LOCKFILE" ]]; then
    local stale_pid
    stale_pid="$(cat "$LOCKFILE" 2>/dev/null || echo)"
    if [[ -n "$stale_pid" ]] && kill -0 "$stale_pid" 2>/dev/null; then
      echo "Another applyloop update is already running (pid $stale_pid). Aborting." >&2
      exit 1
    fi
    log "Stale lock from dead pid $stale_pid — clearing"
    rm -f "$LOCKFILE"
  fi
  echo $$ > "$LOCKFILE"
  trap 'rm -f "$LOCKFILE"' EXIT

  log "git fetch origin $APPLYLOOP_BRANCH"
  git -C "$APPLYLOOP_HOME" fetch origin "$APPLYLOOP_BRANCH"
  git -C "$APPLYLOOP_HOME" reset --hard "origin/$APPLYLOOP_BRANCH"

  # Arch self-heal — if the existing venv was built for a different arch
  # (user migrated Macs, or originally installed under Rosetta), wipe and
  # rebuild from a native-arch brew Python before reinstalling deps. Same
  # check install.sh does, replicated here so `applyloop update` alone is
  # enough to recover without re-running the curl installer.
  local host_arch venv_arch
  host_arch="$(uname -m)"
  if [[ -x "$APPLYLOOP_HOME/venv/bin/python3" ]]; then
    venv_arch="$("$APPLYLOOP_HOME/venv/bin/python3" -c 'import platform; print(platform.machine())' 2>/dev/null || echo unknown)"
    if [[ "$venv_arch" != "$host_arch" ]]; then
      log "venv arch '$venv_arch' != host '$host_arch' — rebuilding from native brew python"
      local brew_py=""
      if command -v brew >/dev/null 2>&1; then
        brew_py="$(brew --prefix python@3.11 2>/dev/null)/bin/python3.11"
      fi
      if [[ -z "$brew_py" || ! -x "$brew_py" ]]; then
        echo "Cannot rebuild venv: native python@3.11 not found via brew." >&2
        echo "Re-run the curl installer to fix:" >&2
        echo "  curl -fsSL https://raw.githubusercontent.com/snehitvaddi/ApplyLoop/main/install.sh | bash" >&2
        exit 1
      fi
      local brew_py_arch
      brew_py_arch="$("$brew_py" -c 'import platform; print(platform.machine())' 2>/dev/null || echo unknown)"
      if [[ "$brew_py_arch" != "$host_arch" ]]; then
        echo "brew python at $brew_py is '$brew_py_arch' (expected '$host_arch')." >&2
        echo "brew is installed under Rosetta. Re-run the curl installer to fix." >&2
        exit 1
      fi
      rm -rf "$APPLYLOOP_HOME/venv"
      "$brew_py" -m venv "$APPLYLOOP_HOME/venv"
    fi
  fi

  log "Reinstalling python deps (single-pass)"
  "$APPLYLOOP_HOME/venv/bin/pip" install --quiet \
    -r "$APPLYLOOP_HOME/packages/desktop/requirements.txt" \
    -r "$APPLYLOOP_HOME/packages/worker/requirements.txt"

  log "Rebuilding static UI"
  (
    cd "$APPLYLOOP_HOME/packages/desktop/ui"
    npm install --silent --cache "$NPM_CONFIG_CACHE" --no-fund --no-audit
    npm run build --silent
  )

  log "Regenerating $APPLYLOOP_APP"
  APPLYLOOP_HOME="$APPLYLOOP_HOME" APPLYLOOP_APP="$APPLYLOOP_APP" \
    bash "$APPLYLOOP_HOME/packages/desktop/scripts/build_local_app.sh"

  # Refresh the CLI symlinks. The installer drops `applyloop` into
  # ~/.local/bin AND (since the brew-bin fix) into the Homebrew bin so
  # it's reliably on PATH. But a user who installed before that fix
  # only has the ~/.local/bin link — and if ~/.local/bin isn't on
  # their PATH, plain `applyloop` keeps failing forever because
  # `update` itself never re-linked. Re-create both links here so one
  # `~/.local/bin/applyloop update` is enough to make plain
  # `applyloop` work afterward.
  local shim_src="$APPLYLOOP_HOME/packages/desktop/scripts/applyloop"
  mkdir -p "$HOME/.local/bin"
  ln -sf "$shim_src" "$HOME/.local/bin/applyloop"
  local brew_bin=""
  if command -v brew >/dev/null 2>&1; then
    brew_bin="$(brew --prefix 2>/dev/null)/bin"
  elif [[ -x /opt/homebrew/bin/brew ]]; then
    brew_bin="/opt/homebrew/bin"
  elif [[ -x /usr/local/bin/brew ]]; then
    brew_bin="/usr/local/bin"
  fi
  if [[ -n "$brew_bin" && -d "$brew_bin" && -w "$brew_bin" ]]; then
    ln -sf "$shim_src" "$brew_bin/applyloop"
    log "Refreshed applyloop CLI symlink in $brew_bin"
  fi

  cmd_stop || true

  git -C "$APPLYLOOP_HOME" rev-parse HEAD > "$APPLYLOOP_HOME/.applyloop-version"
  log "Done. Run: applyloop start"
}

cmd_uninstall() {
  cmd_stop || true

  # Tear down the auto-update launchd plist (Phase F in install.sh). Silently
  # succeed if it was never loaded, or if launchctl bootout is missing (old
  # macOS). Do this before rm so launchctl can still find the file path.
  local plist="$HOME/Library/LaunchAgents/com.applyloop.update.plist"
  if [[ -f "$plist" ]]; then
    log "Unloading launchd: com.applyloop.update"
    launchctl bootout "gui/$(id -u)" "$plist" 2>/dev/null || \
      launchctl unload "$plist" 2>/dev/null || true
    rm -f "$plist"
  fi

  log "Removing $APPLYLOOP_HOME"
  rm -rf "$APPLYLOOP_HOME"
  log "Removing $APPLYLOOP_APP"
  rm -rf "$APPLYLOOP_APP"
  log "Removing $HOME/.local/bin/applyloop"
  rm -f "$HOME/.local/bin/applyloop"
  # Also drop the worker token from the runtime workspace so a subsequent
  # fresh install doesn't inherit a stale token.
  rm -f "$HOME/.autoapply/workspace/.api-token"
  echo
  echo "Uninstalled. (Workspace at ~/.autoapply preserved — delete manually for a clean wipe.)"
}

usage() {
  cat <<USAGE
Usage: applyloop <command>

Commands:
  start       Open /Applications/ApplyLoop.app (launches the wizard)
  run         Chat with Claude Code in this terminal (no .app window)
  stop        Kill the running launch.py server
  status      GET /api/health and pretty-print JSON
  logs        Tail ~/.autoapply/desktop.log
  update      git pull + reinstall deps + rebuild UI + regen .app
  uninstall   Remove ~/.applyloop, the .app bundle, and this shim

Env:
  APPLYLOOP_HOME    ($APPLYLOOP_HOME)
  APPLYLOOP_APP     ($APPLYLOOP_APP)
  APPLYLOOP_PORT    ($PORT)
USAGE
}

case "${1:-}" in
  start)     cmd_start ;;
  run)       cmd_run ;;
  stop)      cmd_stop ;;
  status)    cmd_status ;;
  logs)      cmd_logs ;;
  update)    cmd_update ;;
  uninstall) cmd_uninstall ;;
  ""|-h|--help|help) usage ;;
  *)         echo "Unknown command: $1" >&2; usage; exit 1 ;;
esac
