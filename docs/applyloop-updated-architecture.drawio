        <!-- PTY Claude reads AGENTS.MD -->
        <mxCell id="c-pty-agents" value="&lt;font size='8'&gt;reads on start&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;strokeColor=#F57C00;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="pty-claude" target="agents-md">
